# X11 programs need to know where to display windows (should be automatic)
#export DISPLAY=:0

# chmod 750 permissions by default
#umask 0027

# Should not have to set manually (macOS, was not happy without it)
export TERM=xterm-256color

#export PATH=/path/:$PATH
#export LD_LIBRARY_PATH=/path:LD_LIBRARY_PAT

if [ -f ~/.my_profile ]; then
  source ~/.my_profile 2> /dev/null
fi

if ! command -v direnv &> /dev/null; then
    echo "direnv not found. Installing..."
    if [[ "$OSTYPE" == "darwin"* ]]; then
        brew install direnv
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        sudo apt update && sudo apt install direnv -y
    fi
fi
if command -v direnv &> /dev/null; then
    eval "$(direnv hook zsh)"
fi

# personal executatbles...
mkdir -p export PATH="$HOME/.local/bin/"
export PATH="$HOME/.local/bin/:$PATH"

#alias mac="ssh <username>@<host> -L 5902:localhost:5900"

export REMOTE_OLLAMA="192.168.2.237:11434"
alias ollama-remote='OLLAMA_HOST="http://${REMOTE_OLLAMA}" ollama'
