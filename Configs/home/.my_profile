#### Installation ####
# File: .zshrc or .bashrc or ...
# Add:  source ~/.my_profile
# Done

### Determine OS being used ###
_my_os=$(uname -s)
case $_my_os in
  Linux)      _my_os='linux' ;;
  WindowsNT)  _my_os='dos' ;;
  Darwin)     _my_os='macOS' ;;
  *)          ;;
esac

### Determine ARCH being used ###
_my_arch=$(uname -m)
case $_my_arch in
  x86_64) _my_arch=x64 ;;  # or AMD64 or Intel64
  i*86)   _my_arch=x86 ;;  # or IA32 or Intel32
  *)      ;;
esac

### Determine DISTRO being used ###
if [[ "$_my_os" == "linux" ]]; then
  if [ -f /etc/os-release ]; then
    . /etc/os-release
    if [[ "$ID" == "ubuntu" || "$ID_LIKE" == *"debian"* ]]; then
      _my_distro="debian"
    elif [[ "$ID" == *"rhel"* || "$ID_LIKE" == *"rhel"* || "$ID" == "fedora" ]]; then
      _my_distro="rhel"
    else
      _my_distro="$ID"
    fi
  else
    _my_distro="unknown_linux"
  fi
elif [[ "$_my_os" == "macOS" ]]; then
  _my_distro="darwin"
fi
 
### Determine SHELL being used ###
if [ -n "$ZSH_VERSION" ]; then
  _my_shell="zsh"
elif [ -n "$BASH_VERSION" ]; then
  _my_shell="bash"
else
  _my_shell="unknown"
fi

### Determine TERM being used ###
_my_term=$TERM
if [[ $_my_term == *xterm* ]]; then
  _my_term=xterm
fi

### Verbose ###
if [[ "$*" == *"-v"* ]]; then
  echo "$_my_os | $_my_distro | $_my_arch | $_my_term | $_my_shell"
  echo ""
fi

### Terminal History ###
# Saving HISTFILESIZE lines to disk and loading the last HISTSIZE lines into memory
HISTSIZE=10000
HISTFILESIZE=50000

# Append history from each session, not the last terminal to log out
if [[ $_my_shell == bash ]]; then
  shopt -s histappend > /dev/null 2>&1
  # Add commands immediately to history, do not wait for log out
  export PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"
elif [[ $_my_shell == zsh ]]; then
  setopt INC_APPEND_HISTORY > /dev/null 2>&1
fi

### Configuration(s) ###
# expand aliases for non-interactive shell (i.e. scripts)
if [[ $_my_shell == bash ]]; then
  shopt -s expand_aliases
elif [[ $_my_shell == zsh ]]; then
  setopt aliases
fi

### Shared Variables & Aliases ###
export EDITOR='vim'

if type htop > /dev/null 2>&1; then
  alias top='htop'
fi

alias vi='vim'
alias curl='noglob curl'
alias god='sudo'  # not the real God, hence lowercase.
alias please='god'
alias c='clear'
alias h='history'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias mkdir='mkdir -pv'

if [[ $_my_os == macOS ]]; then
  alias df='df -ha'
  alias ls='ls -GpF'
  alias timeout='gtimeout' # gnu util for macOS
  alias ps='ps aux'
else
  alias df='df -Tha'
  alias ls='ls -pF --color=auto'
  alias ps='ps auxf'
fi

alias du='du -ach'
alias free='free -mt'
alias here='find . -iname'
alias whereami='hostname'
alias whatami='uname -a'
alias echoerr='>&2 echo'
alias now='date +"%m-%d-%Y %T.%3N"'  # w/ millisecond
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias random="cat /dev/urandom | tr -cd 'a-f0-9' | head -c 64"
alias psf='ps -e | grep -v grep | grep -i -e VSZ -e' # search process match
alias l='ls'
alias ll='ls -lAh'
alias l.='ls -d .*'
alias la='ls -lah'

# ISO-8601 compliant date (in mongodb format)
alias utc='date -u "+%Y-%m-%dT%H:%M:%S.%3NZ"'
alias duck='du -cks -- * | sort -rn | head'

# Replace default tooling with better similar option
if type ag > /dev/null 2>&1; then
  alias awk='ag'
fi
if type autojump > /dev/null 2>&1; then
  alias j='autojump'
fi

alias mounts='mount | column -t | grep "/mnt/"'
alias twitter='sudo rainbowstream -iot'
alias irc='weechat'

### Functions ###

# system backup
backup() {
  _backup_file=/tmp/backup_$(date '+%Y_%m_%d-%H_%M_%S').tar.gz
  sudo rsync --recursive --links --hard-links --whole-file --owner --group --devices --specials --times --perms --acls --xattrs --numeric-ids --info=progress2 --exclude='*.ecryptfs/*' --exclude='/proc' --exclude='/sys' --exclude='/mnt' --exclude='/media' --exclude='/run' --exclude='/dev' --exclude='/tmp' --exclude='/ram' --exclude='/scratch' / .
  sudo touch "$_backup_file"
  sudo tar --create --gzip --preserve-permissions --verbose --exclude='./backup_*' --file="$_backup_file" .
  sudo cp "$_backup_file" .
}

# usage: retry <command>
retry() {
  _result=1
  while [ $_result -ne 0 ]; do 
    "$@" && break 
    _result=$?
    sleep 3
  done
}

# public ip
ipPub() {
  curl -s checkip.dyndns.org | sed -e 's/.*Current IP Address: //' -e 's/<.*$//'
}

# speed test
speedtest() {
  if type speedtest-cli > /dev/null 2>&1; then
    speedtest-cli
  elif [ -x "$HOME/.local/bin/speedtest-cli" ]; then
    "$HOME/.local/bin/speedtest-cli"
  else
    ipPub
    curl -o /dev/null http://speedtest.wdc01.softlayer.com/downloads/test10.zip
  fi
}

# scan network
network() {
  arp-scan --localnet
}

# like dos
pause() {
  read -rsp $'Press any key to continue...\n' -n 1 key
}

# searches in files for match
herein() {
  if [ -n "$1" ] && [[ "$1" == "-s" ]]; then
    shift
    grep -Rni -A 1 -B 1 . -e "$@"
  else
    grep -Rnli . -e "$@"
  fi
}

# list some info after each cd
cd() {
  if [ -n "$1" ]; then
    builtin cd "$@" && pwd && ls
  else
    builtin cd ~ && pwd && ls
  fi
}

ssh() {
  if type autossh > /dev/null 2>&1; then
    autossh -M 0 -o "ServerAliveInterval 30" -o "ServerAliveCountMax 3" "$@"
  else
    echo "Hint: install 'autossh'"
    command ssh "$@"
  fi
}

# makes default session and starts if already running
screen() {
  local _session="default"
  if [ -z "$1" ]; then
    if [ -z "$STY" ]; then
      if [[ $(command screen -list) != *"$_session"* ]]; then
        command screen -D -R "$_session"
      else
        command screen -xr "$_session"
      fi
    fi
  else
     command screen "$@"
  fi
}

mux() {
  if [ "$1" == "-k" ]; then
    if [ -n "$2" ]; then
      command tmux kill-session -t "$2"
    else
      command tmux kill-session
    fi
  else
    command mux "$@"
  fi
}

# kill vnc window(s) option added
vncserver() {
  if [[ "$1" == "-kill" && "$2" == "all" ]]; then
    for v in ~/.vnc/*.pid; do
      [ -e "$v" ] || continue
      local _window=$(basename "$v" .pid)
      command vncserver -kill "$_window"
    done
  else
    command vncserver "$@"
  fi
}

# --split <filename> [size], --join <filename>
split() {
  local _size="214748364" # ~2G default
  if [[ "$1" == "--join" ]]; then
    if [ -f "$2" ]; then
      rm -i "$2"
    fi
    ls *.part* | sort | xargs cat >> "$2"
  elif [[ "$1" == "--split" ]]; then
    if [ -n "$3" ]; then
      _size="$3"
    fi
    command split -b "$_size" "$2" "$2.part"
  else
    command split "$@"
  fi
}

# make space in terminal for scrolling
s() {
  space
}

space() {
  for i in {1..50}; do
    echo ""
  done
  clear
}

# terminal screen saver (matrix)
if type cmatrix > /dev/null 2>&1; then
  tss() {
    cmatrix
    clear
  }
fi

# change priority of interfaces (i.e. to swap priority)
ifswap() {
  if [ $# -ne 2 ]; then
    ifconfig 
    echo ""
    echo "Pick higher and lower interface priority"
    echo "Example:  ifswap enp0 eno1"
  elif type ifmetric > /dev/null 2>&1; then
    ifmetric "$1" 0
    ifmetric "$2" 1
  fi
}

# sleep until a 24hr time
if [[ $_my_os == macOS ]]; then
  sleepuntil() {
      local target_time="$1"
      [ -z "$target_time" ] && return 1
      local now=$(date +%s)
      local target=$(date -j -f "%H:%M" "$target_time" "+%s" 2>/dev/null)
      [ -z "$target" ] && return 1
      if [ "$target" -le "$now" ]; then
          target=$((target + 86400))
      fi
      sleep $((target - now))
  }
else
  sleepuntil() {
      local target_time="$1"
      [ -z "$target_time" ] && return 1
      local now_epoch=$(date +%s)
      local target_epoch=$(date -d "$target_time" +%s 2>/dev/null)
      [ -z "$target_epoch" ] && return 1
      if [ "$target_epoch" -le "$now_epoch" ]; then
          target_epoch=$(date -d "tomorrow $target_time" +%s)
      fi
      sleep $((target_epoch - now_epoch))
  }
fi

### Key Bindings ###
if [[ $_my_term == xterm ]]; then
  stty erase '^?'
fi

if [[ $_my_shell == zsh ]]; then
  bindkey '\e[1~' beginning-of-line
  bindkey '\e[4~' end-of-line
fi

### Other macOS Specifics ###
if [[ $_my_os == macOS ]]; then
  if type archey > /dev/null 2>&1; then
    archey
  fi
  alias afplay='afplay -q 1'
  source ~/.sounds/.sound > /dev/null 2>&1
fi

function finish {
  echo ""
}
trap finish EXIT

### Custom AI Tooling ###

# openclaw default if nothing
openclaw() {
  if [ $# -eq 0 ]; then
    command openclaw tui
  else
    command openclaw "$@"
  fi
}

# claude freedom
claude() {
    local model="${1:-glm-4.7-flash}"
    [[ $# -gt 0 ]] && shift
    
    # Run Claude with temporary environment variables so they don't leak into the shell
    ANTHROPIC_AUTH_TOKEN="ollama" \
    ANTHROPIC_BASE_URL="http://localhost:11434" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_CODE_SKIP_WELCOME=1 \
    CLAUDE_CODE_ACTION="bypassPermissions" \
    CLAUDE_CODE_TRUST_ALL=1 \
    CLAUDE_CODE_DISABLE_TELEMETRY=true \
    CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=true \
    command claude --model "$model" --dangerously-skip-permissions "$@"
}
